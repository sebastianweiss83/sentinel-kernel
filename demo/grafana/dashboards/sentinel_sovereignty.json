{
  "uid": "sentinel-sovereignty",
  "title": "Sentinel Sovereignty Dashboard",
  "tags": ["sentinel", "sovereignty", "eu-ai-act"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Decisions per minute",
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(sentinel_decisions_total[1m])",
          "legendFormat": "decisions/min",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Policy result distribution",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (policy_result) (sentinel_policy_result_total)", "legendFormat": "{{policy_result}}", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Sovereignty score",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sentinel_sovereignty_score", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 0.6, "color": "orange"},
              {"value": 0.9, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "EU AI Act article coverage",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sentinel_eu_ai_act_article_compliant", "legendFormat": "{{article}}", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Kill switch",
      "gridPos": {"h": 8, "w": 4, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sentinel_kill_switch_active", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "NORMAL"}, "1": {"text": "ENGAGED"}}}
          ],
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 1, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Days to EU AI Act enforcement",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sentinel_days_to_enforcement", "refId": "A"}]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latency (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, rate(sentinel_latency_ms_bucket[1m]))", "legendFormat": "p95", "refId": "A"}]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Acknowledged gaps (migration plans)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sentinel_acknowledged_gap", "format": "table", "refId": "A"}]
    }
  ]
}
